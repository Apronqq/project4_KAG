APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

MODEL=qwen3-max
RERANK_MODEL=qwen3-vl-rerank
RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DEVICE=cpu
DENSE_EMBEDDING_DIM=1024
DASHSCOPE_API_KEY=
RERANK_API_KEY=
ENABLE_LLM_INPUT_PARSING=true
ENABLE_REMOTE_RERANK=true

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DATABASE=neo4j
USE_IN_MEMORY_GRAPH=false

MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=medical_evidence_chunks
USE_IN_MEMORY_EVIDENCE=false
EVIDENCE_EMBEDDING_DIM=1024

DATA_ROOT=./data
KNOWLEDGE_UPLOAD_ROOT=./data/knowledge_uploads
KNOWLEDGE_REGISTRY_PATH=./data/knowledge_registry.json

TOP_K_EVIDENCE=5
BOOTSTRAP_KB_ON_STARTUP=false
DROP_MILVUS_COLLECTION_ON_REBUILD=true
ENABLE_LLM_INPUT_PARSING=true
ENABLE_REMOTE_RERANK=true 